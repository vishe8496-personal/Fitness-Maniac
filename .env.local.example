# ── Supabase ──────────────────────────────────────────────
# Project URL + service role key (server-only). Get from Supabase dashboard → Settings → API.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Secrets for signing session tokens (use long random strings) ──
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
ADMIN_JWT_SECRET=change-me-admin-secret
MEMBER_JWT_SECRET=change-me-member-secret
OTP_HASH_SECRET=change-me-otp-secret

# ── OTP provider ──────────────────────────────────────────
# One of: mock | msg91 | twilio
# mock => OTP is printed to the server console instead of sent (great for local dev)
OTP_PROVIDER=mock

# MSG91 (India). Create an OTP/SMS flow and copy the values.
MSG91_AUTHKEY=
MSG91_SENDER_ID=
MSG91_DLT_TEMPLATE_ID=

# Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Default country code prepended to bare mobile numbers (e.g. 91 for India)
DEFAULT_COUNTRY_CODE=91
